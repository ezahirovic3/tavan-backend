APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_CLIENT_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local        # use r2 on production
QUEUE_CONNECTION=database    # use redis on production

CACHE_STORE=database         # use redis on production
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@tavan.store"
MAIL_FROM_NAME="Tavan"

RESEND_API_KEY=re_your_api_key_here

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

TELESCOPE_ENABLED=true

VITE_APP_NAME="${APP_NAME}"

WWWUSER=1000
WWWGROUP=1000

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Cloudflare R2 (image storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tavan
R2_ENDPOINT=
R2_URL=https://cdn.tavan.store

# App Version Gate
# Bump APP_MIN_VERSION to force users on older builds to update (hard gate)
# Bump APP_RECOMMENDED_VERSION to show a soft "update available" prompt
APP_MIN_VERSION=0.0.1
APP_RECOMMENDED_VERSION=0.0.1
APP_IOS_STORE_URL=https://apps.apple.com/app/tavan/id123456789
APP_ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=ba.tavan.app

# Google OAuth (get client IDs from Google Cloud Console)
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/social/google/callback

# Apple Sign In (get from Apple Developer portal)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Set to true once app is established to require admin review for new seller listings
LISTINGS_REQUIRE_REVIEW=false
